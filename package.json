{
  "name": "@alcyone-labs/workalot-monorepo",
  "version": "2.0.0-alpha",
  "private": true,
  "description": "High-performance, multi-threaded job queue system with telemetry and dashboard (pnpm REQUIRED - npm not supported)",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @alcyone-labs/workalot run build",
    "build:telemetry": "pnpm --filter @alcyone-labs/workalot-telemetry run build",
    "build:dashboard": "pnpm --filter @alcyone-labs/workalot-dashboard run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "test:run": "pnpm -r run test:run",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "dashboard": "pnpm --filter @alcyone-labs/workalot-dashboard run start",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
