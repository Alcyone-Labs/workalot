{
  "name": "@alcyone-labs/workalot",
  "version": "2.0.0-alpha",
  "description": "High-performance, multi-threaded job queue system for NodeJS/BunJS. Achieve high throughput jobs/sec with linear worker scaling.",
  "keywords": [
    "high-performance",
    "job-queue",
    "multi-threaded",
    "scaling",
    "task-management",
    "worker-threads"
  ],
  "homepage": "https://github.com/alcyone-labs/workalot#readme",
  "bugs": {
    "url": "https://github.com/alcyone-labs/workalot/issues"
  },
  "license": "MIT",
  "author": "Nicolas Embleton <nicolas.embleton@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alcyone-labs/workalot.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#/*": "./src/*",
    "#examples/jobs/*": "./examples/_jobs/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && cp -r src/queue/migrations dist/queue/",
    "build:examples": "tsc --project tsconfig.examples.json && tsc-alias --project tsconfig.examples.json",
    "build:all": "pnpm run build && pnpm run build:examples",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --project tsconfig.examples.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "benchmark": "pnpm run build && bun run benchmarks/run-benchmarks.ts",
    "benchmark:easy": "pnpm run build && bun run benchmarks/run-benchmarks.ts --difficulty easy",
    "benchmark:quick": "pnpm run build && bun run benchmarks/run-benchmarks.ts --configs 2-cores-10k-jobs,4-cores-10k-jobs",
    "benchmark:quick:easy": "pnpm run build && bun run benchmarks/run-benchmarks.ts --configs 2-cores-10k-jobs,4-cores-10k-jobs --difficulty easy",
    "benchmark:nodejs": "pnpm run build && node dist/benchmarks/run-benchmarks.js --difficulty easy",
    "benchmark:nodejs:quick": "pnpm run build && node dist/benchmarks/run-benchmarks.js --configs 2-cores-10k-jobs,4-cores-10k-jobs --difficulty easy",
    "benchmark:bun": "bun run benchmarks/run-benchmarks.ts --difficulty easy",
    "benchmark:bun:quick": "bun run benchmarks/run-benchmarks.ts --configs 2-cores-10k-jobs,4-cores-10k-jobs --difficulty easy",
    "benchmark:deno": "deno run --allow-all benchmarks/run-benchmarks.ts --difficulty easy",
    "benchmark:deno:quick": "deno run --allow-all benchmarks/run-benchmarks.ts --configs 2-cores-10k-jobs,4-cores-10k-jobs --difficulty easy",
    "benchmark:compare": "./benchmarks/compare-runtimes.sh easy 2-cores-10k-jobs,4-cores-10k-jobs",
    "benchmark:compare:full": "./benchmarks/compare-runtimes.sh normal 2-cores-10k-jobs,4-cores-10k-jobs,6-cores-10k-jobs",
    "benchmark:sqlite": "./benchmarks/run-sqlite-benchmarks.sh easy",
    "benchmark:sqlite:normal": "./benchmarks/run-sqlite-benchmarks.sh normal",
    "benchmark:backends": "./benchmarks/run-backend-comparison.sh easy 4 1k",
    "benchmark:backends:10k": "./benchmarks/run-backend-comparison.sh easy 4 10k",
    "example:quick-start": "pnpm run build && bun run examples/quick-start.ts",
    "example:performance": "pnpm run build && bun run examples/performance-test.ts",
    "example:errors": "pnpm run build && bun run examples/error-handling.ts",
    "example:fullstack": "bun run examples/full-stack/backend/server.ts",
    "examples": "pnpm run example:quick-start",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/opentelemetry": "^1.4.10",
    "@elysiajs/static": "^1.4.7",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.68.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-metrics": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/sdk-trace-node": "^2.5.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "elysia": "^1.4.22",
    "ioredis": "^5.9.2",
    "postgres": "^3.4.8",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.6",
    "@types/cli-progress": "^3.11.6",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^25.0.10",
    "@vitest/coverage-v8": "^4.0.17",
    "cli-progress": "^3.12.0",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17"
  },
  "optionalDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "better-sqlite3": "^12.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.28.1"
}
