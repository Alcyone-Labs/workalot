{
  "name": "task-management",
  "version": "1.0.0",
  "description": "Multi-threaded job queue system for NodeJS/BunJS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "job-queue",
    "multi-threaded",
    "worker-threads",
    "nodejs",
    "bunjs",
    "task-management"
  ],
  "author": "",
